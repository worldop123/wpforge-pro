# ============================================
backups/
*.bak
*.backup
*.zip
*.tar.gz
*.rar
*.7z

# ============================================
# Docker
# ============================================
docker-compose.override.yml
docker-compose.*.override.yml
.dockerignore

# ============================================
# WordPress 特定
# ============================================
wp-config.php
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-content/backups/
.htaccess
robots.txt

# ============================================
