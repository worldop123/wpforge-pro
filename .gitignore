# ============================================
# WPForge .gitignore
# ============================================

# ============================================
# 环境变量和配置
# ============================================
.env
.env.local
.env.*.local
*.env

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# 虚拟环境
venv/
env/
ENV/
.venv/
.env/

# pytest 和覆盖率
.pytest_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# pytype
.pytype/

# ============================================
# Node.js / 前端
# ============================================
node_modules/
dist/
dist-ssr/
*.local
.vite/

# 构建输出
build/
out/
.next/
.nuxt/
.vuepress/dist/

# 缓存
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 依赖锁文件 (可选，根据团队约定)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ============================================
# IDE 和编辑器
# ============================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, PyCharm, WebStorm等)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ============================================
# 操作系统
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp

# Linux
*~

# ============================================
# 数据库
# ============================================
*.db
*.sqlite
*.sqlite3
*.sql
*.dump

# ============================================
# 日志文件
# ============================================
*.log
logs/
*.log.*

# ============================================
# 临时文件
# ============================================
tmp/
temp/
tmp-*
*.tmp
*.bak
*.backup
*.old

# ============================================
# 数据和上传文件
# ============================================
data/
uploads/
media/
files/
storage/

# ============================================
