# ============================================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ============================================
# 其他
# ============================================
# 项目特定的忽略
*.pid
*.seed
*.pid.lock

# 本地配置
local-config.php
local-config.json
local-config.yaml

# 测试覆盖率
coverage/

# 文档构建
docs/_build/
docs/build/
site/

# ============================================
# 项目特定
# ============================================
# WPForge 特定
wpforge-theme.zip
wpforge-plugin.zip
release/
releases/

# 演示数据
demo-data/
sample-data/
test-data/

# 截图和录屏
screenshots/
recordings/

# ============================================
# 注释说明
