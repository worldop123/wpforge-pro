[run]
source = app
omit =
    */tests/*
    */test_*
    */migrations/*
    */site-packages/*
    */venv/*
    */__pycache__/*
    app/main.py
    app/config.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    if TYPE_CHECKING:
    @abstractmethod
    pass
    \.\.\.
    if False:
    if __debug__:
    @overload
    @typing.overload

show_missing = True
skip_covered = False
fail_under = 70

[html]
directory = htmlcov
title = WPForge Coverage Report

[xml]
output = coverage.xml

[paths]
source =
    app/
    */site-packages/*/app/
