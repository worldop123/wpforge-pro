# WPForge Relay Server 配置示例
# 复制此文件为 .env 并修改配置

# 服务器配置
RELAY_PORT=3001
RELAY_HOST=0.0.0.0
CORS_ORIGIN=*

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SQLite配置
SQLITE_PATH=./data/relay.db

# JWT配置
JWT_SECRET=wpforge-relay-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 认证配置
ADMIN_API_KEY=admin-api-key-change-in-production
SUPER_ADMIN_API_KEY=super-admin-api-key-change-in-production

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/relay.log

# 环境
NODE_ENV=development
