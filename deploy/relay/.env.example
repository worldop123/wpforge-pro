# WPForge Relay 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ===== 服务器配置 =====
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ===== Redis配置 =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT配置 =====
JWT_SECRET=wpforge-relay-secret-key-change-me-to-a-random-string
JWT_EXPIRES_IN=7d
JWT_ISSUER=wpforge-relay

# ===== 认证配置 =====
# 管理员API Key（用于管理端连接）
ADMIN_API_KEY=admin-api-key-change-me-to-a-random-string

# 超级管理员API Key（拥有最高权限）
SUPER_ADMIN_API_KEY=super-admin-api-key-change-me-to-a-random-string

# ===== CORS配置 =====
CORS_ORIGIN=*

# ===== 消息配置 =====
# 消息最大大小（字节）
MESSAGE_MAX_SIZE=1048576

# 离线消息保留时间（秒）
MESSAGE_TTL=604800

# 最大离线消息数
MAX_OFFLINE_MESSAGES=1000

# ===== 心跳配置 =====
# 心跳间隔（毫秒）
HEARTBEAT_INTERVAL=30000

# 心跳超时（毫秒）
HEARTBEAT_TIMEOUT=10000

# 最大错过心跳次数
HEARTBEAT_MAX_MISSED=3

# ===== 限流配置 =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=1
RATE_LIMIT_BLOCK_DURATION=60

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ===== 管理面板配置 =====
# API基础URL
VITE_API_BASE_URL=http://localhost:3001

# ===== 数据库配置（SQLite） =====
SQLITE_PATH=./data/relay.db
