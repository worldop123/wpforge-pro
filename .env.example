# ============================================
# WPForge 环境配置示例
# 复制此文件为 .env 并根据实际情况修改
# ============================================

# ============================================
# 基础配置
# ============================================
APP_NAME=WPForge
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+psycopg2://wpforge:wpforge@postgres:5432/wpforge

# ============================================
# Redis配置
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_DB=1
REDIS_BACKEND_DB=2

# ============================================
# Celery配置
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ============================================
# JWT安全配置
# ============================================
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# AI模型配置
# ============================================
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama 本地模型
OLLAMA_BASE_URL=http://localhost:11434

# 默认AI配置
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o-mini

# ============================================
# Playwright配置
# ============================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=100
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_USER_DATA_DIR=

# ============================================
# 反检测配置
# ============================================
STEALTH_ENABLED=true
RANDOM_DELAY_MIN=1.0
RANDOM_DELAY_MAX=3.0
HUMAN_LIKE_SCROLL=true

# ============================================
# 代理配置
# ============================================
# BrightData
BRIGHTDATA_USER=
BRIGHTDATA_PASSWORD=
BRIGHTDATA_HOST=zproxy.lum-superproxy.io
BRIGHTDATA_PORT=22225

# Oxylabs
OXYLABS_USER=
OXYLABS_PASSWORD=
OXYLABS_HOST=pr.oxylabs.io
OXYLABS_PORT=7777

# Smartproxy
SMARTPROXY_USER=
SMARTPROXY_PASSWORD=
SMARTPROXY_HOST=gate.smartproxy.com
SMARTPROXY_PORT=7000

# 默认代理提供商
DEFAULT_PROXY_PROVIDER=none
PROXY_ENABLED=false

# ============================================
# 采集配置
# ============================================
MAX_CONCURRENT_SCRAPERS=3
SCRAPER_DELAY_BETWEEN_REQUESTS=2.0
MAX_RETRIES=3

# ============================================
# 翻译配置
# ============================================
# DeepL
DEEPL_API_KEY=

# Google Translate
GOOGLE_TRANSLATE_API_KEY=

DEFAULT_SOURCE_LANG=auto
DEFAULT_TARGET_LANG=en
TRANSLATION_BATCH_SIZE=50

# ============================================
# 汇率配置
# ============================================
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_CACHE_TTL=3600
DEFAULT_CURRENCY=USD
TARGET_CURRENCY=EUR

# ============================================
# WordPress配置
# ============================================
WP_DEFAULT_USER=admin
WP_DEFAULT_PASSWORD=admin

# ============================================
# 安全配置
# ============================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=300
RATE_LIMIT_PER_MINUTE=60

# ============================================
# CORS配置
# ============================================
CORS_ORIGINS=["*"]

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=

# ============================================
# 监控告警配置
# ============================================
# 邮件告警
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# Telegram告警
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack告警
SLACK_WEBHOOK_URL=
